{
  "manifest_version": 3,
  "name": "PaperBack Agent",
  "version": "1.0.0",
  "description": "브라우징 기록과 기사 본문을 수집하여 PaperBack 저널을 생성합니다",
  "permissions": [
    "history",
    "activeTab",
    "storage",
    "alarms",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/Readability.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://paperback-agent.fly.dev/auth/extension-done*"],
      "js": ["auth-callback.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
